# Backend env — copy to backend/.env and fill in for local dev.
# Production secrets live in /etc/teknav/secrets.env on the Debian host (NOT in git).

DATABASE_URL="postgresql://teknav:teknav_dev@localhost:5432/teknav?schema=public"
REDIS_URL="redis://localhost:6379"

# 32+ random bytes; required even in dev. Generate: `openssl rand -base64 48`
SESSION_SECRET="CHANGE_ME_RANDOM_BYTES_AT_LEAST_32_CHARS"

# Cookie scope. Leave empty in dev; in prod set to your apex domain (e.g. ".teknav.ir").
COOKIE_DOMAIN=""

# Where uploaded images go.
UPLOAD_DIR="./uploads"

# Comma-separated origins allowed by CORS. Use http://localhost:3009 for the Vite dev server.
CORS_ORIGINS="http://localhost:3009"

# Server port (Fastify). Frontend talks to /api/* via the reverse proxy in prod.
PORT=3010

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── OAuth ────────────────────────────────────────────────────────────────────
# Base URL for OAuth callback redirect URIs. In dev: http://localhost:3009
OAUTH_CALLBACK_BASE=http://localhost:3009
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
